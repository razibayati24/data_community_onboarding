{
  "datasets": [
    {
      "name": "kpi_677e4972",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT SUM(critical_alarms) total_critical, SUM(active_alarms) total_active, ROUND(AVG(avg_mttr_min),1) network_mttr, COUNT(*) sites FROM cmegdemos_catalog.att_data_community.gold_site_health"
      ]
    },
    {
      "name": "gold_24d50784",
      "displayName": "Site health",
      "queryLines": [
        "SELECT\n",
        "  site_id,\n",
        "  site_name,\n",
        "  region,\n",
        "  state,\n",
        "  vendor,\n",
        "  equipment_type,\n",
        "  latitude,\n",
        "  longitude,\n",
        "  total_alarms,\n",
        "  critical_alarms,\n",
        "  active_alarms,\n",
        "  avg_mttr_min,\n",
        "  fault_score\n",
        "FROM\n",
        "  cmegdemos_catalog.att_data_community.gold_site_health"
      ]
    },
    {
      "name": "region_40df9f85",
      "displayName": "By region",
      "queryLines": [
        "SELECT region, COUNT(*) sites, SUM(critical_alarms) critical_alarms, SUM(active_alarms) active_alarms, ROUND(AVG(avg_mttr_min),1) avg_mttr FROM cmegdemos_catalog.att_data_community.gold_site_health GROUP BY region"
      ]
    },
    {
      "name": "top_db0980a6",
      "displayName": "Top sites",
      "queryLines": [
        "SELECT\n",
        "  site_id,\n",
        "  site_name,\n",
        "  region,\n",
        "  state,\n",
        "  vendor,\n",
        "  fault_score\n",
        "FROM\n",
        "  cmegdemos_catalog.att_data_community.gold_site_health\n",
        "ORDER BY\n",
        "  fault_score DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "alarm_forecast",
      "displayName": "Alarm Forecast by Region",
      "queryLines": [
        "WITH daily_alarms AS (\n",
        "  SELECT\n",
        "    CAST(event_date AS TIMESTAMP) AS ds,\n",
        "    COUNT(*) AS alarm_count\n",
        "  FROM\n",
        "    cmegdemos_catalog.att_data_community.silver_alarms\n",
        "  GROUP BY\n",
        "    event_date\n",
        "),\n",
        "forecasted AS (\n",
        "  SELECT\n",
        "    *\n",
        "  FROM\n",
        "    ai_forecast(\n",
        "      TABLE(daily_alarms),\n",
        "      horizon => CAST('2026-06-22' AS TIMESTAMP),\n",
        "      time_col => 'ds',\n",
        "      value_col => 'alarm_count',\n",
        "      parameters => '{\"global_floor\": 0}'\n",
        "    )\n",
        ")\n",
        "SELECT\n",
        "  ds,\n",
        "  alarm_count AS actual,\n",
        "  CAST(NULL AS DOUBLE) AS forecast\n",
        "FROM\n",
        "  daily_alarms\n",
        "UNION ALL\n",
        "SELECT\n",
        "  ds,\n",
        "  CAST(NULL AS DOUBLE),\n",
        "  CAST(alarm_count AS DOUBLE)\n",
        "FROM\n",
        "  daily_alarms\n",
        "WHERE\n",
        "  ds\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(ds)\n",
        "      FROM\n",
        "        daily_alarms\n",
        "    )\n",
        "UNION ALL\n",
        "SELECT\n",
        "  ds,\n",
        "  CAST(NULL AS DOUBLE),\n",
        "  alarm_count_forecast\n",
        "FROM\n",
        "  forecasted"
      ]
    }
  ],
